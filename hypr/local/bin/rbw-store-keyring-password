#!/usr/bin/env sh

xdg_config_home=${XDG_CONFIG_HOME:-$HOME/.config}
python_bin=${RBW_KEYRING_PYTHON:-/usr/bin/python3}
qdbus_bin=${RBW_KEYRING_QDBUS:-/usr/bin/qdbus6}

if [ -n "${RBW_PROFILE:-}" ]; then
  config_file="$xdg_config_home/rbw-${RBW_PROFILE}/config.json"
  profile_name="$RBW_PROFILE"
else
  config_file="$xdg_config_home/rbw/config.json"
  profile_name="default"
fi

wallet_name() {
  if [ -n "${RBW_KEYRING_KWALLET:-}" ]; then
    printf '%s\n' "$RBW_KEYRING_KWALLET"
    return 0
  fi

  if [ -x "$qdbus_bin" ]; then
    "$qdbus_bin" org.kde.kwalletd6 /modules/kwalletd6 org.kde.KWallet.localWallet 2>/dev/null && return 0
    "$qdbus_bin" org.kde.kwalletd6 /modules/kwalletd6 org.kde.KWallet.networkWallet 2>/dev/null && return 0
  fi

  printf 'kdewallet\n'
}

if [ ! -r "$config_file" ]; then
  printf 'rbw config not found: %s\n' "$config_file" >&2
  exit 1
fi

if [ ! -x "$qdbus_bin" ]; then
  printf 'qdbus6 is required\n' >&2
  exit 1
fi

email=$("$python_bin" - "$config_file" <<'PY'
import json
import sys

with open(sys.argv[1], "r", encoding="utf-8") as fh:
    config = json.load(fh)

email = config.get("email")
if isinstance(email, str):
    print(email, end="")
PY
)

if [ -z "$email" ]; then
  printf 'rbw config is missing email\n' >&2
  exit 1
fi

if [ -t 0 ] && [ -r /dev/tty ]; then
  printf 'Bitwarden master password for %s: ' "$email" >&2
  stty -echo < /dev/tty
  IFS= read -r password < /dev/tty
  stty echo < /dev/tty
  printf '\n' >&2
else
  IFS= read -r password
fi

if [ -z "$password" ]; then
  printf 'no password entered\n' >&2
  exit 1
fi

entry_name="rbw:${profile_name}:${email}"
wallet=$(wallet_name)
handle=$(
  "$qdbus_bin" org.kde.kwalletd6 /modules/kwalletd6 org.kde.KWallet.open "$wallet" 0 rbw-store-keyring-password 2>/dev/null
) || {
  printf 'Failed to open KWallet "%s"\n' "$wallet" >&2
  exit 1
}
case "$handle" in
  ''|-[0-9]*)
    printf 'Failed to open KWallet "%s"\n' "$wallet" >&2
    exit 1
    ;;
esac

folder_exists=$(
  "$qdbus_bin" org.kde.kwalletd6 /modules/kwalletd6 org.kde.KWallet.hasFolder "$handle" rbw rbw-store-keyring-password 2>/dev/null
) || folder_exists=false

if [ "$folder_exists" != "true" ]; then
  create_result=$(
    "$qdbus_bin" org.kde.kwalletd6 /modules/kwalletd6 org.kde.KWallet.createFolder "$handle" rbw rbw-store-keyring-password 2>/dev/null
  ) || create_result=false

  if [ "$create_result" != "true" ]; then
    printf 'Failed to create KWallet folder "rbw" in "%s"\n' "$wallet" >&2
    exit 1
  fi
fi

write_result=$(
  "$qdbus_bin" org.kde.kwalletd6 /modules/kwalletd6 org.kde.KWallet.writePassword "$handle" rbw "$entry_name" "$password" rbw-store-keyring-password 2>/dev/null
) || write_result=-1

if [ "$write_result" = "0" ]; then
  printf 'Stored rbw password in KWallet "%s" folder "rbw" entry "%s"\n' "$wallet" "$entry_name"
else
  printf 'Failed to store rbw password in KWallet "%s"\n' "$wallet" >&2
  exit 1
fi
