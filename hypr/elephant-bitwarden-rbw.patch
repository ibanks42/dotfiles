+
+func copyWithCommand(command string, identifier string, logStr string) {
+	cmd := common.ReplaceResultOrStdinCmd(command, identifier)
+	err := cmd.Start()
+	if err != nil {
+		slog.Error(Name, fmt.Sprintf("%s failed", logStr), err)
+		return
+	}
+
+	go func() {
+		if err := cmd.Wait(); err != nil {
+			slog.Error(Name, fmt.Sprintf("%s failed", logStr), err)
+			return
+		}
+
+		exec.Command("notify-send", fmt.Sprintf("%s succeeded", logStr)).Run()
+		clearClipboard()
+	}()
+}
