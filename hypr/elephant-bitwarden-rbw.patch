 func initItems() {
 	cachedItems = nil
-	cmd := exec.Command("rbw", "list", "--raw")
+	cmd := exec.Command("rbw", "list", "--fields", "id,name,user,folder")
 	output, err := cmd.CombinedOutput()
 	if err != nil {
 		slog.Error(Name, "init", err, "msg", output)
