+			parts = append(parts, "")
+		}
+
+		cachedItems = append(cachedItems, RbwItem{
+			ID:     strings.TrimSpace(parts[0]),
+			Name:   strings.TrimSpace(parts[1]),
+			User:   strings.TrimSpace(parts[2]),
+			Folder: strings.TrimSpace(parts[3]),
+		})
 	}
 }
